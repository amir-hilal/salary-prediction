# ─── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ─── Virtual environments ────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Environment / Secrets ───────────────────────────────
.env
*.env.local
.env.*
!.env.example

# ─── Kaggle ──────────────────────────────────────────────
~/.kaggle/

# ─── Data ────────────────────────────────────────────────
data/raw/*
!data/raw/.gitkeep
data/external/*
!data/external/.gitkeep

# ─── Model artifacts ─────────────────────────────────────
models/artifacts/*
!models/artifacts/.gitkeep
models/registry/*
!models/registry/.gitkeep

# ─── Jupyter ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Testing & Coverage ──────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ─── Linting / Typing ────────────────────────────────────
